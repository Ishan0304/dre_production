# Python caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local configuration and secrets
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/

# Generated outputs
artifacts/*
reports/*
outputs/*
!artifacts/.gitkeep
!reports/.gitkeep
!outputs/reports/
outputs/reports/*
!outputs/reports/examples/
!outputs/reports/examples/*.png
!outputs/reports/examples/.gitkeep

# Data
data/*
!data/.gitkeep
!data/README.md
!data/manifests/
!data/manifests/*.txt
!data/raw/
data/raw/*
!data/raw/.gitkeep

# Editor settings
.vscode/
.idea/

# OS junk files
.DS_Store
Thumbs.db
desktop.ini
